# ══════════════════════════════════════════════
# VYBE — Environment Variables
# Copy to .env.local and fill in your values
# ══════════════════════════════════════════════

# ── Supabase ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Stripe ─────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...

# ── Scanner ────────────────────────────────────
# Must be a 64-char random hex string — used for QR HMAC signing
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SCANNER_HMAC_SECRET=your_64_char_hex_secret_here

# ── Email ──────────────────────────────────────
RESEND_API_KEY=re_...

# ── Storage / Images ───────────────────────────
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ── Monitoring ─────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ── App ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ── Environments ───────────────────────────────
# development → Supabase vybe-dev    → Stripe test mode
# staging     → Supabase vybe-staging → Stripe test mode
# production  → Supabase vybe-prod   → Stripe live mode
